# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
.env.*
*.env
secrets.json
secrets.yaml
secrets.toml

# ── Database — contains live trade data, not for version control ──────────────
data/markets.db
data/*.db
data/*.sqlite
data/*.sqlite3

# ── Exported reports (regenerate from DB) ────────────────────────────────────
data/*.csv
data/*.md
data/*.txt

# ── Streamlit cache / state ───────────────────────────────────────────────────
.streamlit/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Claude context (local only) ───────────────────────────────────────────────
.claude/
