# Streamlit Community Cloud — Secrets template
#
# 1. Go to share.streamlit.io → your app → Settings → Secrets
# 2. Paste the contents below with your real values filled in
# 3. Click Save — the app restarts with secrets injected
#
# This file is safe to commit (it has no real values).
# NEVER create secrets.toml with real values — it is gitignored.

# ── Live data ──────────────────────────────────────────────────────────────────
USE_REAL_DATA   = "true"
PRODUCTION_MODE = "false"    # set to "true" when going live with real money

# ── Fees ───────────────────────────────────────────────────────────────────────
TAKER_FEE_PCT = "2.0"        # verify current rate at polymarket.com before live

# ── Polymarket CLOB credentials ────────────────────────────────────────────────
# Required only for live order execution (app/execution.py).
# Leave blank for paper-trading / dashboard-only use.
POLY_PRIVATE_KEY    = ""     # 0x + 64 hex chars — your Polygon wallet private key
POLY_API_KEY        = ""     # from polymarket.com/profile → API Keys
POLY_API_SECRET     = ""
POLY_API_PASSPHRASE = ""
