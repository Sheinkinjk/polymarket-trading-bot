# Streamlit Community Cloud — Secrets template
#
# 1. Go to share.streamlit.io → your app → ⋮ menu → Settings → Secrets
# 2. Paste the block below with real values filled in
# 3. Save — Streamlit injects these as environment variables automatically
#
# This example file is safe to commit (no real values).
# Never create a real secrets.toml with actual credentials.

USE_REAL_DATA   = "true"
PRODUCTION_MODE = "false"
TAKER_FEE_PCT   = "2.0"

# Leave blank until you are ready to go live with real money
POLY_PRIVATE_KEY    = ""
POLY_API_KEY        = ""
POLY_API_SECRET     = ""
POLY_API_PASSPHRASE = ""
